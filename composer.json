{
  "name": "arafa/laravel-deadcode-detector",
  "description": "Detect and report dead / unused code in Laravel applications.",
  "type": "library",
  "license": "MIT",
  "keywords": [
    "laravel",
    "dead-code",
    "static-analysis",
    "unused-code",
    "cleanup"
  ],
  "authors": [
    {
      "name": "Ahmed Arafa",
      "email": "arafa.dev@gmail.com"
    }
  ],
  "require": {
    "php": "^8.0",
    "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0",
    "illuminate/console": "^8.0|^9.0|^10.0|^11.0|^12.0",
    "illuminate/contracts": "^8.0|^9.0|^10.0|^11.0|^12.0",
    "nikic/php-parser": "^4.15|^5.0",
    "psr/log": "^1.0|^2.0|^3.0"
  },
  "require-dev": {
    "orchestra/testbench": "^6.0|^7.0|^8.0|^9.0|^10.0",
    "phpunit/phpunit": "^9.0|^10.0|^11.0"
  },
  "autoload": {
    "psr-4": {
      "Arafa\\DeadcodeDetector\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Arafa\\DeadcodeDetector\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Arafa\\DeadcodeDetector\\DeadCodeServiceProvider"
      ]
    }
  },
  "config": {
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
